<div class="container mt-3">
  <div class="d-flex">
    <div>
      <h2>Your Applications</h2>
    </div>
    <div class="mx-3">
      <%= link_to "New Application", new_user_application_path, class: "btn btn-primary" %>
    </div>
  </div>
  <ul class="list-group">
  <% @user_applications.each do |user_application| %>
    <li class="list-group-item">
      <%= link_to user_application.title, user_application_chat_path(user_application, user_application.chats.last) %>
      <%= link_to "Delete", user_application_path(user_application), data: {turbo_method: "delete", turbo_confirm: "Are you sure?"}, class: "btn btn-warning" %>
    </li>
  <% end %>
</div>
