<div class="bgg-img">
  <div class="apps">
    <div class="d-flex align-items-center justify-content-between mb-4">
      <h2 class="mb-0 fw-bold">Your Applications</h2>
      <%= link_to "New Application", new_user_application_path, class: "btn btn-primary rounded-5" %>
    </div>
    <% @user_applications.each do |user_application| %>
      <div class="app d-flex justify-content-between align-items-center">
      <%= link_to user_application_chat_path(user_application, user_application.chats.last), class: "text-decoration-none flex-grow-1" do %>
        <div class="app-title nextlineVertwo"><%= user_application.title %> <br>
          <span class="text-secondary fs-6"> Created: <%= user_application.created_at.localtime.strftime('%b %d, %Y %l:%M %P') %> </span>
        </div>
      <% end %>
      <div>
        <%= link_to user_application_path(user_application), data: {turbo_method: "delete", turbo_confirm: "Are you sure?"} do %>
          <i class="fa-solid fa-trash-can"></i>
        <% end %>
      </div>
    </div>
    <% end %>
  </div>
</div>
