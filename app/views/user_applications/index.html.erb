<div class="bgg-img">
  <div class="apps">
    <div class="d-flex align-items-center justify-content-between mb-4">
      <h2 class="mb-0 fw-bold">Your Applications</h2>
      <%= link_to "New Application", new_user_application_path, class: "btn btn-primary rounded-5" %>
    </div>

    <% @user_applications.each do |user_application| %>
      <%= link_to user_application_chat_path(user_application, user_application.chats.last), class: "app" do %>
        <div class="app-title nextlineVertwo"><%= user_application.title %> <br>
          Create at: <%= user_application.created_at %>
        </div>
      <% end %>
    <% end %>
  </div>
</div>
